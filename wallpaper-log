#!/usr/bin/env bash
# =============================================================================
#  wallpaper-log
# -----------------------------------------------------------------------------
#  Central logging helper. Every event in the wallpaper-rotator system writes
#  through this script so the format stays consistent and the file gets
#  trimmed in one place.
#
#  Usage:
#      wallpaper-log <EVENT_TYPE> [detail...]
#
#  Examples:
#      wallpaper-log AUTO     /home/user/.local/share/backgrounds/foo.jpg
#      wallpaper-log MANUAL   /home/user/.local/share/backgrounds/bar.jpg
#      wallpaper-log ON
#      wallpaper-log OFF
#      wallpaper-log INTERVAL "2min -> 1h"
#
#  All entries get a timestamp prefix. When the log file grows past MAX_LINES
#  entries, the oldest ones are trimmed off so the file never balloons.
# =============================================================================

set -euo pipefail

# Canonical log path: kept within the cloned project directory to be completely
# self-contained and portable. Override with the WALLPAPER_LOG env var if you
# want it somewhere else.
REPO_DIR="<REPO_DIR_PLACEHOLDER>"
LOG="${WALLPAPER_LOG:-$REPO_DIR/wallpaper.log}"

# Guard: if the default in-repo log location is gone (folder moved or deleted),
# don't silently recreate a ghost folder. Warn and skip logging. Exit 0 so the
# monitor (which runs under `set -e`) keeps running. A custom WALLPAPER_LOG
# location is still created as before.
log_dir="$(dirname "$LOG")"
if [ ! -d "$log_dir" ]; then
    if [ -z "${WALLPAPER_LOG:-}" ]; then
        echo "wallpaper-rotator: project folder '$REPO_DIR' not found (moved or deleted)." >&2
        echo "Re-run install.sh from its new location to restore logging." >&2
        exit 0
    fi
    mkdir -p "$log_dir"
fi

# Max number of entries to keep. After each write, anything older than the
# most recent MAX_LINES gets dropped. 500 ≈ a few weeks at hourly rotation.
MAX_LINES=500

# First argument is the event tag (AUTO / MANUAL / ON / OFF / INTERVAL).
# Default to UNKNOWN if nothing was passed (shouldn't happen, but safe).
event="${1:-UNKNOWN}"
shift || true

# Everything after the event tag is treated as the detail field (a path,
# a "before -> after" interval, etc.). Empty is fine for ON/OFF events.
detail="${*:-}"

# Make sure the log file exists so the trim step doesn't error on first run.
touch "$LOG"

# Format: "YYYY-MM-DD HH:MM:SS  EVENT     detail"
# The %-9s padding keeps the EVENT column aligned for easy scanning.
ts=$(date '+%Y-%m-%d %H:%M:%S')
printf '%s  %-9s %s\n' "$ts" "$event" "$detail" >> "$LOG"

# Trim the file to the most recent MAX_LINES entries.
# We use a temp file + atomic move so a crash mid-trim can't truncate the log.
lines=$(wc -l < "$LOG")
if [ "$lines" -gt "$MAX_LINES" ]; then
    # Create the temp file in the log's own directory so the mv below is an
    # atomic same-filesystem rename (mktemp's default /tmp could be a different
    # mount, making mv a non-atomic copy+delete).
    tmp=$(mktemp -p "$(dirname "$LOG")")
    tail -n "$MAX_LINES" "$LOG" > "$tmp"
    mv "$tmp" "$LOG"
fi
